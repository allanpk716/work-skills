{
  "version": "2.0",
  "project": "go-calculator",
  "language": "go",
  "scanned_at": "2026-04-18T16:30:00.000Z",
  "collections": [
    {
      "id": "col-calculator",
      "name": "Calculator System",
      "description": "Arithmetic expression calculator with REST API, batch processing, and history query flows",
      "flows": ["flow-api-calculate", "flow-batch-process", "flow-history-query"]
    }
  ],
  "flows": [
    {
      "id": "flow-api-calculate",
      "name": "REST API Calculation",
      "trigger": "POST /api/calculate",
      "entry": "internal/api/server.go:HandleCalculate",
      "sequence": ["cp-api-calc-entry", "cp-calc-parse", "cp-calc-validate", "cp-calc-compute", "cp-calc-format", "cp-api-calc-done"],
      "shared_points": ["cp-calc-parse", "cp-calc-validate", "cp-calc-compute", "cp-calc-format"]
    },
    {
      "id": "flow-batch-process",
      "name": "Batch Processing",
      "trigger": "CLI --batch / --expr",
      "entry": "internal/batch/processor.go:ProcessExpressions",
      "sequence": ["cp-batch-entry", "cp-calc-parse", "cp-calc-validate", "cp-calc-compute", "cp-calc-format", "cp-batch-done"],
      "shared_points": ["cp-calc-parse", "cp-calc-validate", "cp-calc-compute", "cp-calc-format"]
    },
    {
      "id": "flow-history-query",
      "name": "History Query with Recompute",
      "trigger": "GET /api/history/{id}",
      "entry": "internal/api/server.go:HandleHistoryGet",
      "sequence": ["cp-history-entry", "cp-history-lookup", "cp-calc-parse", "cp-calc-validate", "cp-calc-compute", "cp-calc-format", "cp-history-done"],
      "shared_points": ["cp-calc-parse", "cp-calc-validate", "cp-calc-compute", "cp-calc-format"]
    }
  ],
  "points": [
    {
      "id": "cp-api-calc-entry",
      "location": "internal/api/server.go:65",
      "type": "entry",
      "description": "Entry point for REST API calculation flow",
      "flows": ["flow-api-calculate"]
    },
    {
      "id": "cp-api-calc-done",
      "location": "internal/api/server.go:80",
      "type": "state-change",
      "description": "API calculation complete, result stored",
      "flows": ["flow-api-calculate"]
    },
    {
      "id": "cp-batch-entry",
      "location": "internal/batch/processor.go:27",
      "type": "entry",
      "description": "Entry point for batch processing flow",
      "flows": ["flow-batch-process"]
    },
    {
      "id": "cp-batch-done",
      "location": "internal/batch/processor.go:55",
      "type": "state-change",
      "description": "Batch expression evaluation complete",
      "flows": ["flow-batch-process"]
    },
    {
      "id": "cp-history-entry",
      "location": "internal/api/server.go:101",
      "type": "entry",
      "description": "Entry point for history query flow",
      "flows": ["flow-history-query"]
    },
    {
      "id": "cp-history-lookup",
      "location": "internal/api/server.go:112",
      "type": "boundary",
      "description": "History store lookup before recompute",
      "flows": ["flow-history-query"]
    },
    {
      "id": "cp-history-done",
      "location": "internal/api/server.go:127",
      "type": "state-change",
      "description": "History recompute complete, response sent",
      "flows": ["flow-history-query"]
    },
    {
      "id": "cp-calc-parse",
      "location": "internal/calculator/calculator.go:16",
      "type": "boundary",
      "description": "Shared: Expression parsing (tokenizer)",
      "flows": ["flow-api-calculate", "flow-batch-process", "flow-history-query"]
    },
    {
      "id": "cp-calc-validate",
      "location": "internal/calculator/calculator.go:52",
      "type": "boundary",
      "description": "Shared: Token validation (syntax check)",
      "flows": ["flow-api-calculate", "flow-batch-process", "flow-history-query"]
    },
    {
      "id": "cp-calc-compute",
      "location": "internal/calculator/calculator.go:103",
      "type": "state-change",
      "description": "Shared: Expression evaluation (recursive descent)",
      "flows": ["flow-api-calculate", "flow-batch-process", "flow-history-query"]
    },
    {
      "id": "cp-calc-format",
      "location": "internal/calculator/calculator.go:116",
      "type": "boundary",
      "description": "Shared: Result formatting",
      "flows": ["flow-api-calculate", "flow-batch-process", "flow-history-query"]
    },
    {
      "id": "cp-calc-error",
      "location": "internal/calculator/calculator.go:184",
      "type": "error",
      "description": "Shared: Division by zero error path",
      "flows": ["flow-api-calculate", "flow-batch-process", "flow-history-query"]
    }
  ]
}
