{
  "description": "Sends Pushover and Windows Toast notifications when Claude Code tasks complete or user attention is needed",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/notify.py\"",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/notify-attention.py\"",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ]
  }
}
