{
  "description": "Sends Pushover and Windows Toast notifications when Claude Code tasks complete",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/claude-notify/hooks/scripts/notify.py\"",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ]
  }
}
